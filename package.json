{
  "name": "smart-bharat-civic-companion",
  "version": "1.0.0",
  "description": "Smart Bharat - AI-Powered Civic Companion for PromptWars 2026",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client"
  },
  "keywords": [
    "civic",
    "companion",
    "smart-bharat",
    "gemini",
    "react",
    "express"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
